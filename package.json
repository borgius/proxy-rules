{
  "name": "proxy-rules",
  "version": "1.0.7",
  "description": "MITM forward proxy with per-domain TypeScript/JavaScript rule plugins",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borgius/proxy-rules.git"
  },
  "bugs": {
    "url": "https://github.com/borgius/proxy-rules/issues"
  },
  "homepage": "https://github.com/borgius/proxy-rules#readme",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "proxy-rules": "./bin/proxy-rules"
  },
  "exports": {
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite-node src/index.ts -- serve",
    "dev:watch": "vite-node --watch src/index.ts -- serve",
    "start": "vite-node src/index.ts -- serve",
    "build": "node ./scripts/build.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepublishOnly": "npm run test && npm run typecheck && npm run build",
    "release": "node ./scripts/release.mjs"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "http-proxy": "^1.18.1",
    "node-forge": "^1.3.1",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.15",
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.11",
    "typescript": "^5.5.4",
    "vite": "^7.3.1",
    "vite-node": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
