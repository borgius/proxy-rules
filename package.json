{
  "name": "proxy-rules",
  "version": "1.0.2",
  "description": "MITM forward proxy with per-domain TypeScript rule plugins",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borgius/proxy-rules.git"
  },
  "bugs": {
    "url": "https://github.com/borgius/proxy-rules/issues"
  },
  "homepage": "https://github.com/borgius/proxy-rules#readme",
  "engines": {
    "bun": ">=1.3.9"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "proxy-rules": "./dist/index.js"
  },
  "exports": {
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "node ./scripts/build.mjs",
    "test": "bun test",
    "typecheck": "bun run --bun tsc --noEmit",
    "lint": "bun run --bun eslint src",
    "prepublishOnly": "bun run test && bun run typecheck && bun run build",
    "release": "node ./scripts/release.mjs"
  },
  "dependencies": {
    "http-proxy": "^1.18.1",
    "node-forge": "^1.3.1",
    "commander": "^12.1.0",
    "zod": "^3.23.8",
    "picocolors": "^1.1.1",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.15",
    "@types/node-forge": "^1.3.11",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.9",
    "typescript": "^5.5.4"
  }
}
